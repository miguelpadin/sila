{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "sila-fawn.vercel.app"
        }
      ],
      "destination": "https://www.silapadin.com/:path*",
      "statusCode": 301
    }
  ]
}
